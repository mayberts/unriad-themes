/* =========================
   FOLDER DROPDOWN BUTTON
   ========================= */

button.folder-dropdown:hover,
button[class*="folder-dropdown"]:hover {
    color: #4ab3e8 !important;
    box-shadow:
        0 0 12px rgba(74,179,232,0.40) !important;
}
